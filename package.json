{
  "name": "openpkg",
  "version": "0.1.0",
  "description": "Developer operating center for environment health, projects, caches, and tooling.",
  "type": "module",
  "bin": {
    "openpkg": "./dist/cli.js",
    "opkg": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "keywords": [
    "cli",
    "tui",
    "developer-tools",
    "environment",
    "cleanup",
    "terminal"
  ],
  "author": "João Vitor de Mello <joaovdmello@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melloxyz/openpkg-cli.git"
  },
  "bugs": {
    "url": "https://github.com/melloxyz/openpkg-cli/issues"
  },
  "homepage": "https://github.com/melloxyz/openpkg-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "gradient-string": "^3.0.0",
    "ink": "^7.0.2",
    "react": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
